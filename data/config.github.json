{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": [
      "zh",
      "en"
    ],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "startups-funding"
      },
      {
        "name": "Product Hunt",
        "url": "https://www.producthunt.com/feed",
        "enabled": true,
        "category": "new-products"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "36氪",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "chinese-tech-business"
      },
      {
        "name": "a16z",
        "url": "https://a16z.com/feed/",
        "enabled": true,
        "category": "venture-capital"
      },
      {
        "name": "Entrepreneur",
        "url": "https://www.entrepreneur.com/feed",
        "enabled": true,
        "category": "entrepreneurship"
      },
      {
        "name": "Crunchbase News",
        "url": "https://news.crunchbase.com/feed/",
        "enabled": true,
        "category": "startups-funding"
      },
      {
        "name": "虎嗅",
        "url": "https://www.huxiu.com/rss/0.xml",
        "enabled": true,
        "category": "chinese-tech-business"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "YC Blog",
        "url": "https://www.ycombinator.com/blog/feed.xml",
        "enabled": true,
        "category": "startups"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "startups",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "entrepreneur",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "technology",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 40
        },
        {
          "subreddit": "fatFIRE",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 15
        },
        {
          "subreddit": "SideProject",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 15
        },
        {
          "subreddit": "SaaS",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "venturecapital",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null
  }
}